# ── MySQL Database ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=bozone

# ── TikTok Shop API ──
# 应用密钥 (App Key) - 来自 Partner Center → 应用详情
TIKTOK_APP_KEY=your_app_key_here
# 应用密钥 (App Secret) - ⚠️ 严禁泄露
TIKTOK_APP_SECRET=your_app_secret_here
# OAuth 回调地址 - 必须与 Partner Center 中填写的完全一致！
TIKTOK_REDIRECT_URI=https://8.138.36.120:3001/api/tiktok/callback

# 授权ID (Service ID) - ⚠️ 多数情况下与 APP_KEY 相同，但如果遇到
# "This service does not exist" 错误，需要在 Partner Center 找到独立的 Service ID 填入
# 获取路径: Partner Center → 你的应用 → 授权信息 → Service ID (授权ID)
# TIKTOK_SERVICE_ID=

# 环境: production 或 sandbox
TIKTOK_ENV=production

# ── TikTok Ads (Business Platform) API — 可选，不填则复用上方 Shop 凭证
TIKTOK_ADS_APP_ID=
TIKTOK_ADS_APP_SECRET=
TIKTOK_ADS_REDIRECT_URI=https://8.138.36.120:3001/api/ads/oauth/callback

# ── Frontend URL ──
FRONTEND_URL=https://8.138.36.120

# ── Server ──
PORT=3001
