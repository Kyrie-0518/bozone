# ── MySQL Database ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=bozone

# ── TikTok Shop API ──
TIKTOK_APP_KEY=your_app_key_here
TIKTOK_APP_SECRET=your_app_secret_here
TIKTOK_REDIRECT_URI=https://8.138.36.120:3001/api/tiktok/callback
TIKTOK_ENV=production

# ── TikTok Ads (Business Platform) API — 可选，不填则复用上方 Shop 凭证
TIKTOK_ADS_APP_ID=
TIKTOK_ADS_APP_SECRET=
TIKTOK_ADS_REDIRECT_URI=https://8.138.36.120:3001/api/ads/oauth/callback

# ── Frontend URL ──
FRONTEND_URL=https://8.138.36.120

# ── Server ──
PORT=3001
